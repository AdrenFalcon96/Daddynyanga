# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/samanyanga

# JWT Secret — change this before going to production!
JWT_SECRET=samanyanga-fixed-secret-change-in-production

# AI — at least one is recommended for full AI chat functionality
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# Video Generation (optional)
SISIF_AI_API_KEY=...

# Server (set automatically by Replit / Render / deployment platform)
PORT=8080
NODE_ENV=development

# Frontend build settings
BASE_PATH=/
SERVE_STATIC=false
