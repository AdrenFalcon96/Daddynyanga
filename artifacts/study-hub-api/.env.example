# ============================================================
# Samanyanga Study Hub - API Server Environment Variables
# ============================================================
# Copy this file to .env.local for development.
# Set all required variables in your Render service configuration.
# The server will refuse to start if any REQUIRED variable is missing.

# ── DATABASE ──────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string.
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/study_hub

# ── AUTHENTICATION ────────────────────────────────────────
# [REQUIRED] Secret used to sign JWT tokens.
# Generate a strong random string: openssl rand -hex 64
JWT_SECRET=change-this-to-a-random-64-char-hex-string

# ── ADMIN CREDENTIALS ─────────────────────────────────────
# [REQUIRED] Admin email address. Never exposed to students.
ADMIN_EMAIL=admin@yourdomain.com

# [REQUIRED] bcrypt hash of the admin password.
# Generate with: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
# Store the HASH here, never the plain password.
ADMIN_PASSWORD_HASH=$2a$12$examplehashgoesherereplacethiswithreal

# [REQUIRED] Recovery code for emergency admin access (read-only mode).
# Generate a strong random string: openssl rand -hex 32
ADMIN_RECOVERY_CODE=change-this-to-a-random-32-char-hex-string

# ── AI INTEGRATION ────────────────────────────────────────
# [OPTIONAL] OpenRouter API key for the AI tutor.
# Get one at: https://openrouter.ai/keys
# If not set, the AI tutor falls back to the local knowledge base.
OPENROUTER_API_KEY=sk-or-v1-...

# ── SERVER ────────────────────────────────────────────────
# Port the API server listens on.
# Render sets this automatically. Default: 8081
PORT=8081

# Node environment. Use 'production' in deployment.
NODE_ENV=production
